      "inputs": {"x": "5", "y": "100"},
      "expected_outputs": {"result": "10"}
    },
    {
      "name": "match_variable_10",
      "inputs": {"x": "10", "y": "7"},
      "expected_outputs": {"result": "20"}
    },
    {
      "name": "match_variable_1",
      "inputs": {"x": "1", "y": "999"},
      "expected_outputs": {"result": "2"}
    }
